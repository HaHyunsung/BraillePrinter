<Window x:Class="BraillePrinter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="м җмһҗ н”„лҰ°н„° HMI"
        Height="760" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="#EEEEEE">

    <Window.Resources>
        <!-- нҲҙл°” лІ„нҠј -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- нҢЁл„җ н—ӨлҚ” -->
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- мғҒнғңл°” н…ҚмҠӨнҠё -->
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- нҲҙл°” -->
            <RowDefinition Height="*"/>     <!-- л©”мқё мҪҳн…җмё  -->
            <RowDefinition Height="Auto"/>  <!-- мғҒнғңл°” -->
        </Grid.RowDefinitions>

        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
             нҲҙл°”
        в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,8">

                <TextBlock Text="м җмһҗ н”„лҰ°н„°"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#1565C0"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <Button x:Name="BtnConvert"
                        Style="{StaticResource ToolBtn}"
                        Content="в–¶  ліҖнҷҳ"
                        Background="#1565C0" Foreground="White"
                        Click="BtnConvert_Click"/>

                <Button x:Name="BtnClear"
                        Style="{StaticResource ToolBtn}"
                        Content="м§Җмҡ°кё°"
                        Click="BtnClear_Click"/>

                <Rectangle Width="1" Height="22" Fill="#CCCCCC" Margin="8,0"/>

                <Button x:Name="BtnParam"
                        Style="{StaticResource ToolBtn}"
                        Content="вҡҷ  нҢҢлқјлҜён„° м„Өм •"
                        Click="BtnParam_Click"/>

                <Rectangle Width="1" Height="22" Fill="#CCCCCC" Margin="8,0"/>

                <!-- мқёмҮ„ лІ„нҠј (н•ҳл“ңмӣЁм–ҙ лҜёнҷ•м • вҖ” л№„нҷңм„ұ) -->
                <Button x:Name="BtnPrint"
                        Style="{StaticResource ToolBtn}"
                        Content="рҹ–Ё  мқёмҮ„ (мӨҖл№„ мӨ‘)"
                        IsEnabled="False"
                        Opacity="0.5"/>
            </StackPanel>
        </Border>

        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
             л©”мқё мҪҳн…җмё : н…ҚмҠӨнҠё мһ…л Ҙ | м җмһҗ лҜёлҰ¬ліҙкё°
        в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
        <Grid Grid.Row="1" Margin="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- в”Җв”Җ мҷјмӘҪ нҢЁл„җ: н…ҚмҠӨнҠё мһ…л Ҙ в”Җв”Җ -->
            <DockPanel Grid.Column="0">

                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource PanelHeader}"
                           Text="н•ңкёҖ н…ҚмҠӨнҠё мһ…л Ҙ"/>

                <!-- м •ліҙ нҢЁл„җ -->
                <Border DockPanel.Dock="Bottom"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelHeader}"
                                   Text="ліҖнҷҳ м •ліҙ" Margin="0,0,0,4"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="мһ…л Ҙ кёҖмһҗмҲҳ:" Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCharCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="м җмһҗ м…Җ мҲҳ:"  Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCellCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="м җ к°ңмҲҳ:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoDotCount"  Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="мӮ¬мҡ© мӨ„:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoLineCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="м…Җ мҡ©лҹү:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCapacity"  Text="-" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- н…ҚмҠӨнҠёл°•мҠӨ -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1"
                        Background="White" CornerRadius="4">
                    <TextBox x:Name="InputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             FontFamily="л§‘мқҖ кі л”•, Malgun Gothic"
                             Padding="8"
                             BorderThickness="0"
                             VerticalAlignment="Stretch"
                             TextChanged="InputTextBox_TextChanged"
                             ToolTip="н•ңкёҖ н…ҚмҠӨнҠёлҘј мһ…л Ҙн•ҳм„ёмҡ”"/>
                </Border>
            </DockPanel>

            <!-- в”Җв”Җ кө¬л¶„м„  в”Җв”Җ -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Width="4"
                          Background="#CCCCCC"
                          Cursor="SizeWE"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- в”Җв”Җ мҳӨлҘёмӘҪ нҢЁл„җ: м җмһҗ лҜёлҰ¬ліҙкё° в”Җв”Җ -->
            <DockPanel Grid.Column="2">

                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource PanelHeader}"
                           Text="м җмһҗ лҜёлҰ¬ліҙкё° (A4)"/>

                <!-- мҡ©м§Җ лҜёлҰ¬ліҙкё° мҳҒм—ӯ.
                     ScrollViewer л°°кІҪмқ„ нҡҢмғүмңјлЎң м„Өм •н•ҳкі ,
                     PaperBorderлҠ” HorizontalAlignment="Center"лЎң Canvas нҒ¬кё°м—җ л§һкІҢл§Ң л°°м№ҳ.
                     мқҙл ҮкІҢ н•ҙм•ј Canvas(A4 л№„мңЁ)лҘј мҙҲкіјн•ҙ Borderк°Җ лҠҳм–ҙлӮҳм§Җ м•ҠмҠөлӢҲлӢӨ. -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#909090">
                    <Border x:Name="PaperBorder"
                            Background="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3"
                                              Opacity="0.35" Color="Black"/>
                        </Border.Effect>
                        <Canvas x:Name="BrailleCanvas"
                                Background="White"
                                ClipToBounds="True"/>
                    </Border>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
             мғҒнғңл°”
        в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ -->
        <StatusBar Grid.Row="2"
                   Background="White"
                   BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusMessage"
                           Style="{StaticResource StatusText}"
                           Text="мӨҖл№„"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusParams"
                           Style="{StaticResource StatusText}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
