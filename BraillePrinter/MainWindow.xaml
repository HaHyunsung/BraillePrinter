<Window x:Class="BraillePrinter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="점자 프린터 HMI"
        Height="760" Width="1200"
        MinHeight="600" MinWidth="900"
        Background="#EEEEEE">

    <Window.Resources>
        <!-- 툴바 버튼 -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 패널 헤더 -->
        <Style x:Key="PanelHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 상태바 텍스트 -->
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 툴바 -->
            <RowDefinition Height="*"/>     <!-- 메인 콘텐츠 -->
            <RowDefinition Height="Auto"/>  <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════
             툴바
        ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="12,8">

                <TextBlock Text="점자 프린터"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#1565C0"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <Button x:Name="BtnConvert"
                        Style="{StaticResource ToolBtn}"
                        Content="▶  변환"
                        Background="#1565C0" Foreground="White"
                        Click="BtnConvert_Click"/>

                <Button x:Name="BtnClear"
                        Style="{StaticResource ToolBtn}"
                        Content="지우기"
                        Click="BtnClear_Click"/>

                <Rectangle Width="1" Height="22" Fill="#CCCCCC" Margin="8,0"/>

                <Button x:Name="BtnParam"
                        Style="{StaticResource ToolBtn}"
                        Content="⚙  파라미터 설정"
                        Click="BtnParam_Click"/>

                <Rectangle Width="1" Height="22" Fill="#CCCCCC" Margin="8,0"/>

                <Button x:Name="BtnLog"
                        Style="{StaticResource ToolBtn}"
                        Content="📋  로그"
                        Click="BtnLog_Click"/>

                <Rectangle Width="1" Height="22" Fill="#CCCCCC" Margin="8,0"/>

                <!-- 인쇄 버튼 (하드웨어 미확정 — 비활성) -->
                <Button x:Name="BtnPrint"
                        Style="{StaticResource ToolBtn}"
                        Content="🖨  인쇄 (준비 중)"
                        IsEnabled="False"
                        Opacity="0.5"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════
             메인 콘텐츠: 텍스트 입력 | 점자 미리보기
        ═══════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="200"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── 왼쪽 패널: 텍스트 입력 ── -->
            <DockPanel Grid.Column="0">

                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource PanelHeader}"
                           Text="한글 텍스트 입력"/>

                <!-- 정보 패널 -->
                <Border DockPanel.Dock="Bottom"
                        Background="White"
                        BorderBrush="#CCCCCC" BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,8"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PanelHeader}"
                                   Text="변환 정보" Margin="0,0,0,4"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="입력 글자수:" Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCharCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="점자 셀 수:"  Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCellCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="점 개수:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoDotCount"  Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="사용 줄:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoLineCount" Text="0" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="셀 용량:"     Width="90" Style="{StaticResource StatusText}"/>
                            <TextBlock x:Name="InfoCapacity"  Text="-" Style="{StaticResource StatusText}" FontWeight="Medium"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 텍스트박스 -->
                <Border BorderBrush="#CCCCCC" BorderThickness="1"
                        Background="White" CornerRadius="4">
                    <TextBox x:Name="InputTextBox"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="14"
                             FontFamily="맑은 고딕, Malgun Gothic"
                             Padding="8"
                             BorderThickness="0"
                             VerticalAlignment="Stretch"
                             TextChanged="InputTextBox_TextChanged"
                             ToolTip="한글 텍스트를 입력하세요"/>
                </Border>
            </DockPanel>

            <!-- ── 구분선 ── -->
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Width="4"
                          Background="#CCCCCC"
                          Cursor="SizeWE"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ── 오른쪽 패널: 점자 미리보기 ── -->
            <DockPanel Grid.Column="2">

                <TextBlock DockPanel.Dock="Top"
                           Style="{StaticResource PanelHeader}"
                           Text="점자 미리보기 (A4)"/>

                <!-- 용지 미리보기 영역.
                     ScrollViewer 배경을 회색으로 설정하고,
                     PaperBorder는 HorizontalAlignment="Center"로 Canvas 크기에 맞게만 배치.
                     이렇게 해야 Canvas(A4 비율)를 초과해 Border가 늘어나지 않습니다. -->
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              Background="#909090">
                    <Border x:Name="PaperBorder"
                            Background="White"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="24">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3"
                                              Opacity="0.35" Color="Black"/>
                        </Border.Effect>
                        <Canvas x:Name="BrailleCanvas"
                                Background="White"
                                ClipToBounds="True"/>
                    </Border>
                </ScrollViewer>
            </DockPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             상태바
        ═══════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="2"
                   Background="White"
                   BorderBrush="#CCCCCC" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="StatusMessage"
                           Style="{StaticResource StatusText}"
                           Text="준비"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusParams"
                           Style="{StaticResource StatusText}"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
