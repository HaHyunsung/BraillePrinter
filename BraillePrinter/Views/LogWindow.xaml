<Window x:Class="BraillePrinter.Views.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="로그 뷰어 — liblouis.log"
        Height="520" Width="860"
        MinHeight="300" MinWidth="500"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Button" x:Key="LogBtn">
            <Setter Property="Height"     Value="30"/>
            <Setter Property="Padding"    Value="14,0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="4,0"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 툴바 -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,6">
                <Button x:Name="BtnRefresh" Style="{StaticResource LogBtn}"
                        Content="🔄  새로고침" Click="BtnRefresh_Click"/>
                <Button x:Name="BtnAutoScroll" Style="{StaticResource LogBtn}"
                        Content="↓  자동 스크롤: ON" Click="BtnAutoScroll_Click"/>
                <Button x:Name="BtnClear" Style="{StaticResource LogBtn}"
                        Content="🗑  로그 지우기" Click="BtnClear_Click"/>
                <Rectangle Width="1" Height="20" Fill="#444" Margin="8,0"/>
                <TextBlock x:Name="TbLogPath"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="#888"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="450"/>
            </StackPanel>
        </Border>

        <!-- 로그 텍스트 -->
        <ScrollViewer x:Name="LogScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="#1E1E1E"
                      Padding="4">
            <TextBox x:Name="TbLog"
                     IsReadOnly="True"
                     FontFamily="Consolas, Courier New"
                     FontSize="12"
                     Foreground="#D4D4D4"
                     Background="Transparent"
                     BorderThickness="0"
                     TextWrapping="NoWrap"
                     VerticalAlignment="Top"
                     AcceptsReturn="True"/>
        </ScrollViewer>

        <!-- 상태바 -->
        <Border Grid.Row="2" Background="#252526" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10,4">
            <TextBlock x:Name="TbStatus"
                       FontSize="11"
                       Foreground="#888"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
