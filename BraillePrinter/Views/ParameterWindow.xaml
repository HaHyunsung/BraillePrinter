<Window x:Class="BraillePrinter.Views.ParameterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="파라미터 설정"
        Height="600" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 구분선 스타일 -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,14,0,6"/>
        </Style>

        <!-- 파라미터 행 레이아웃 -->
        <Style x:Key="ParamLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="180"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>

        <Style x:Key="ParamTextBox" TargetType="TextBox">
            <Setter Property="Width" Value="80"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
        </Style>

        <Style x:Key="UnitLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Foreground" Value="#777"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="RangeLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <!-- 읽기 전용 계산값 -->
        <Style x:Key="CalcValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <!-- 버튼 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="6,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 파라미터 입력 영역 ── -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 점자 물리 규격 -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="점자 물리 규격 (한국 점자 규정 2020)"/>
                <Separator Margin="0,0,0,8"/>

                <!-- 점간 거리 -->
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="점간 거리 (셀 내부)"/>
                    <TextBox  x:Name="TbDotSpacing"   Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}"  Text="mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="규격: 2.3 ~ 2.5"/>
                </StackPanel>

                <!-- 자간 거리 -->
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="자간 거리 (셀 사이)"/>
                    <TextBox  x:Name="TbCellSpacing"  Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}"  Text="mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="규격: 5.5 ~ 6.9"/>
                </StackPanel>

                <!-- 줄간 거리 -->
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="줄간 거리"/>
                    <TextBox  x:Name="TbLineSpacing"  Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}"  Text="mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="규격: ~10.0"/>
                </StackPanel>

                <!-- 용지 여백 -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="용지 여백"/>
                <Separator Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="좌측 여백"/>
                    <TextBox  x:Name="TbMarginLeft"   Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="상단 여백"/>
                    <TextBox  x:Name="TbMarginTop"    Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="우측 여백"/>
                    <TextBox  x:Name="TbMarginRight"  Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="하단 여백"/>
                    <TextBox  x:Name="TbMarginBottom" Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                </StackPanel>

                <!-- 용지 크기 -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="용지 크기"/>
                <Separator Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="용지 너비"/>
                    <TextBox  x:Name="TbPaperWidth"   Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="A4 = 210"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="용지 높이"/>
                    <TextBox  x:Name="TbPaperHeight"  Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="A4 = 297"/>
                </StackPanel>

                <!-- 화면 설정 -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="화면 표시"/>
                <Separator Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="표시 배율"/>
                    <TextBox  x:Name="TbDisplayScale" Style="{StaticResource ParamTextBox}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="px/mm"/>
                    <TextBlock Style="{StaticResource RangeLabel}" Text="권장: 2.0 ~ 4.0"/>
                </StackPanel>

                <!-- 계산 결과 (읽기 전용) -->
                <TextBlock Style="{StaticResource SectionLabel}" Text="계산 결과 (읽기 전용)"/>
                <Separator Margin="0,0,0,8"/>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="한 줄당 최대 셀 수"/>
                    <TextBlock x:Name="TbCalcCellsPerLine" Style="{StaticResource CalcValue}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="셀"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="최대 줄 수"/>
                    <TextBlock x:Name="TbCalcMaxLines" Style="{StaticResource CalcValue}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="줄"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Style="{StaticResource ParamLabel}" Text="총 셀 용량"/>
                    <TextBlock x:Name="TbCalcTotalCells" Style="{StaticResource CalcValue}"/>
                    <TextBlock Style="{StaticResource UnitLabel}" Text="셀"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 오류 메시지 ── -->
        <TextBlock x:Name="TbError"
                   Grid.Row="1"
                   Foreground="Red" FontSize="11"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- ── 버튼 행 ── -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="BtnSave"    Style="{StaticResource ActionButton}"
                    Content="저장"
                    Background="#1565C0" Foreground="White"
                    Click="BtnSave_Click"/>
            <Button x:Name="BtnDefault" Style="{StaticResource ActionButton}"
                    Content="기본값"
                    Click="BtnDefault_Click"/>
            <Button x:Name="BtnCancel"  Style="{StaticResource ActionButton}"
                    Content="취소"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
